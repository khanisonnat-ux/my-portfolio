# Copy to .env.local and fill in real values from Supabase → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Used by the seed script to bypass RLS. Keep secret.
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL for SEO/OpenGraph/sitemap (e.g. https://yourdomain.com)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
